SUPABASE_URL=
SUPABASE_ANON_KEY=

# REST API Base URL (optional, fallback theo environment)
# Production: https://api.growmate.vn/v1
# Staging: https://api-staging.growmate.vn/v1
# Development: http://localhost:8080/api/v1
API_BASE_URL=

# Feature Flags (true / false)
# Khi false, dùng backend REST API thay vì mock data.
USE_MOCK_API=true

# Bật Supabase RPC hybrid layer (chỉ áp dụng khi USE_MOCK_API=true).
USE_SUPABASE_RPC_DATA_PLANE=true

# Bật agentic backend (FastAPI multi-agent session/orchestrator/WS).
USE_AGENTIC_BACKEND=true

# Agentic Backend URL (required when USE_AGENTIC_BACKEND=true)
AGENTIC_BASE_URL=

# HMAC secret for request signing (shared with backend)
HMAC_SECRET=
